# German A1 Learning Agents - Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit the .env file to Git

# Claude API - get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Shared secret - n8n uses this to authenticate API calls
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=generate-a-random-string-here

# PONS Dictionary API - get from en.pons.com/p/online-dictionary/developers/api
PONS_API_KEY=your-pons-key-here
